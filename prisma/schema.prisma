generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id        String   @id @unique @default(cuid())
  name      String
  role      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String   @unique
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
}

model Branch {
  id      String   @id @default(uuid())
  name    String
  city    String
  clients client[]
  ctes    cte[]
  users   user[]
}

model cte {
  id          String   @id @unique @default(cuid())
  numberCte   String
  openingData DateTime @default(now())
  shipperName String
  clientName  String
  cause       String
  priority    String?
  status      String?
  ro          Int?
  value       Float?
  accountable String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
}

model client {
  id        String   @id @unique @default(cuid())
  name      String
  phone     String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
}

enum BarcodeStatus {
  PENDING
  URGENT
  FINISHED
}

model BarcodeItem {
  id           String        @id @default(uuid())
  barcode      String
  status       BarcodeStatus @default(PENDING)
  readCount    Int           @default(1)
  
  firstReadAt  DateTime      @default(now())
  lastReadAt   DateTime      @default(now())
  
  // Relacionamento com a unidade (opcional, mas recomendado)
  branchId     String?
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([barcode, branchId])
}